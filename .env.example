# ---------------------------------------------------------------------------
# Epis-KG environment configuration
# Copy this file to `.env` and fill in the values before `docker compose up`.
# ---------------------------------------------------------------------------

# --- Neo4j -----------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j
# Used by the neo4j container itself (user/password pair)
NEO4J_AUTH=neo4j/please-change-me

# --- Redis message broker --------------------------------------------------
REDIS_URL=redis://redis:6379/0
INGESTION_STREAM=epis-kg:ingest
REASONING_GROUP=epis-kg-reasoners

# --- LLM provider ----------------------------------------------------------
# Provider is one of: deepseek | anthropic | openai | ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-3-small

# --- Multi-model consensus (hallucination mitigation) ----------------------
# When true, extraction & rhetoric run through TWO LLMs and only items both
# agree on are kept. Requires the primary provider's key AND provider B's key.
EPIS_CONSENSUS_MODE=false
EPIS_CONSENSUS_PROVIDER_B=openai
EPIS_CONSENSUS_MODEL_B=gpt-4o-mini
EPIS_CONSENSUS_THRESHOLD=0.6

# --- Reasoning ------------------------------------------------------------
REASONING_MAX_ATTEMPTS=3
EPIS_LLM_CACHE=true

# DeepSeek via an OpenAI-compatible proxy (default chat provider, low cost).
# >>> PASTE YOUR KEY HERE after copying this file to `.env` (`.env` is git-ignored) <<<
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.gapgpt.app/v1
# Forward provider-specific reasoning knobs (thinking / reasoning_effort).
# Set to false if the endpoint rejects them.
EPIS_REASONING_PARAMS=true

# Anthropic (alternative chat provider)
ANTHROPIC_API_KEY=

# OpenAI (embeddings by default; also chat provider / consensus model B)
OPENAI_API_KEY=

# Ollama (offline / local fallback)
OLLAMA_BASE_URL=http://ollama:11434

# --- Observability ---------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=epis-kg
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# --- API gateway -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Epistemic math hyperparameters ---------------------------------------
# Sensitivity to rhetorical manipulation, contradiction density, temporal staleness
EPIS_ALPHA=0.5
EPIS_BETA=0.35
EPIS_GAMMA=0.15
# Temporal decay constant (per day)
EPIS_LAMBDA=0.05

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/graph
